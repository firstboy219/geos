# =============================================================================
# Geoscan — .env TEMPLATE (KB section 3.4)
# -----------------------------------------------------------------------------
# Ini adalah template yang DI-COMMIT ke git. File .env asli digenerate di
# server oleh scripts/setup_db.sh ke /opt/geoscan/.env dan TIDAK di-commit
# (lihat .gitignore). Salin file ini menjadi .env untuk dev lokal:
#     cp .env.example .env
#
# Catatan realitas server:
#   - Container PostgreSQL existing bernama 'postgres' (postgres:16-alpine),
#     superuser 'admin', default db 'saasdb'. DB Geoscan = 'geoscan'.
#   - Network: geoscan-redis/backend/celery join 'postgres_default'.
#     geoscan-backend JUGA join 'n8n_default' agar n8n hit http://geoscan-backend:8000.
#   - Semua secret di bawah harus di-generate (openssl rand -hex) — JANGAN commit nilai asli.
# =============================================================================

# ── Database ──
# DATABASE_URL pakai driver asyncpg; host = nama container 'postgres'
# (backend/celery berada di network postgres_default, jadi resolve by name).
DATABASE_URL=postgresql+asyncpg://geoscan_user:CHANGE_ME_PASSWORD@postgres:5432/geoscan
DB_HOST=postgres
DB_PORT=5432
DB_NAME=geoscan
DB_USER=geoscan_user
DB_PASSWORD=CHANGE_ME_PASSWORD            # generate: openssl rand -hex 24

# ── Security ──
SECRET_KEY=CHANGE_ME_64_HEX               # generate: openssl rand -hex 32  (=64 hex char)
INTERNAL_API_KEY=CHANGE_ME_32_HEX         # generate: openssl rand -hex 16  (=32 hex char)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis (resolve via nama container di network postgres_default) ──
REDIS_URL=redis://geoscan-redis:6379/0

# ── n8n ──
# geoscan-backend join n8n_default → n8n memanggil backend via http://geoscan-backend:8000.
# Backend memanggil n8n via nama container 'n8n' (port internal 5678).
# Fallback (Linux Docker tidak punya host.docker.internal default):
#   jalankan container dengan --add-host=host.docker.internal:host-gateway
N8N_WEBHOOK_URL=http://n8n:5678

# ── AI (cloud, pay-per-use) — Google Gemini ──
GEMINI_API_KEY=REPLACE_ME                 # https://aistudio.google.com/apikey
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash    # analysis/classification/narrative
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
QDRANT_URL=http://geoscan-qdrant:6333   # self-hosted vector DB (no Pinecone account needed)
PINECONE_API_KEY=pcsk_REPLACE_ME
PINECONE_INDEX_NAME=geoscan-historical
# Embedding dimension — gemini-embedding-001 truncated (MRL) to 1536 to keep the
# Pinecone index dimension unchanged. Create the Pinecone index with dimension 1536, metric cosine.
PINECONE_DIMENSION=1536

# ── External APIs (via n8n credentials — BUKAN di backend) ──
# NEWS_API_KEY → set di n8n credentials (camelCase: newsApiKey)

# ── Firebase Cloud Messaging ──
FIREBASE_CREDENTIALS_JSON=/app/firebase-service-account.json

# ── Stripe (test mode untuk dev) ──
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000,https://apigeo.cosger.online

# ── Monitoring ──
SENTRY_DSN=https://REPLACE_ME@sentry.io/0

# ── Celery (broker & result backend di Redis; concurrency=1 WAJIB; queue 'geoscan') ──
CELERY_BROKER_URL=redis://geoscan-redis:6379/0
CELERY_RESULT_BACKEND=redis://geoscan-redis:6379/1
CELERY_TASK_QUEUE=geoscan
